# PetCost Calculator — environment variables
# Set these in Netlify → Site settings → Environment variables (not committed).

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Resend API key — powers the email-subscribe autoresponder (netlify/functions/submission-created.mts)
# Free tier: 3,000 emails/mo. Create a key at https://resend.com/api-keys
RESEND_API_KEY=

# Verified sender for the autoresponder. The domain must be verified in Resend.
# Until your domain is verified, Resend only allows the from address onboarding@resend.dev
# and only sends to your own account email.
FROM_EMAIL="PetCost Calculator <hello@petcost-calculator.com>"

# Optional — base URL used to build absolute links in emails (defaults to https://petcost-calculator.com)
SITE_URL=https://petcost-calculator.com
